# Public-export posture: ignore everything by default.
# Only explicitly allow files that are clearly safe and useful to publish.

*

# Always ignore secrets, credentials, local environment, caches, and OS noise.
.env
.env.*
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.kdbx
*.sqlite
*.sqlite3
*.db
*.token
*.secret
.DS_Store
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.python-version

# Internal orchestration, plan, and operator files stay private.
do/

# Data and generated artifacts are private by default unless explicitly re-allowed below.
data/
# But allow the docs/data/ generated site-data layer.
!docs/
!docs/**
!docs/data/
!docs/data/site_data.js
results/figures/
results/tables/*
uv.lock

# Re-allow the minimal public surface.
!.gitignore
!.github/
!.github/**
!LICENSE
!Makefile
!README.md
!pyproject.toml
!requirements.txt

